// Setea un valor en un custom-select por data-value
// Reemplaza setSelectValue por esta versión robusta
function setSelectValue(field, value, row = null) {
  if (!value) return;

  const selector = row
    ? `.custom-select[data-field="${field}"][data-row="${row}"]`
    : `.custom-select[data-field="${field}"]`;
  const el = document.querySelector(selector);
  if (!el) return;

  const strValue = String(value).trim();

  // Buscar recorriendo en lugar de querySelector — evita problemas de tipo
  const options = el.querySelectorAll('.select-option');
  let found = null;
  options.forEach(opt => {
    if (String(opt.dataset.value).trim() === strValue) found = opt;
  });

  if (found) {
    selectOptionSilent(el, found);
    el.classList.add('valid');
    el.classList.remove('has-error');
  } else {
    console.warn(`setSelectValue: no encontró opción para field="${field}" value="${strValue}"`);
    // Listar opciones disponibles para diagnóstico
    console.log(`Opciones disponibles en "${field}":`, 
      [...options].map(o => o.dataset.value).join(', ')
    );
  }
}
