                        </div>
                        <select class="pct-select" data-field="pct-gerente" data-row="${rowCounter}">
                            <option value="0.012">1.2%</option><option value="0.01">1%</option><option value="0.009">0.9%</option><option value="0.008">0.8%</option><option value="0.006">0.6%</option><option value="0.005">0.5%</option><option value="0.0042">0.42%</option><option value="0.0036">0.36%</option><option value="0.0035">0.35%</option><option value="0.003">0.3%</option><option value="0.0028">0.28%</option><option value="0.0025">0.25%</option><option value="0.0024">0.24%</option><option value="0.0015">0.15%</option><option value="0.00125">0.125%</option><option value="0.001">0.1%</option><option value="0.00075">0.075%</option><option value="0.0005">0.05%</option><option value="0">0.0%</option><option value="custom">Otro...</option>
                        </select>
                        <input type="number" class="pct-custom-input" data-field="pct-custom-gerente" data-row="${rowCounter}" style="display:none;" placeholder="%" step="0.01" min="0">
                    </div>
                </div>
                <div class="form-group">
                    <label><i class="fas fa-user"></i> Asesor <span style="font-size:0.72rem;color:#555;font-weight:500;text-transform:none;letter-spacing:0;">Opcional</span></label>
                    <div class="participant-group">
                        <div class="custom-select" data-field="asesor" data-row="${rowCounter}" data-api="/api/users/by-role/Asesor">
                            <div class="select-display placeholder">Seleccionar asesor<i class="fas fa-chevron-down select-arrow"></i></div>
                            <div class="select-dropdown"><div class="select-search"><input type="text" placeholder="Buscar asesor..."><i class="fas fa-search"></i></div><div class="select-options"></div></div>
                        </div>
                        <select class="pct-select" data-field="pct-asesor" data-row="${rowCounter}">
                            <option value="0.012">1.2%</option><option value="0.01">1%</option><option value="0.009">0.9%</option><option value="0.008">0.8%</option><option value="0.006">0.6%</option><option value="0.005">0.5%</option><option value="0.0042">0.42%</option><option value="0.0036">0.36%</option><option value="0.0035">0.35%</option><option value="0.003">0.3%</option><option value="0.0028">0.28%</option><option value="0.0025">0.25%</option><option value="0.0024">0.24%</option><option value="0.0015">0.15%</option><option value="0.00125">0.125%</option><option value="0.001">0.1%</option><option value="0.00075">0.075%</option><option value="0.0005">0.05%</option><option value="0">0.0%</option><option value="custom">Otro...</option>
                        </select>
                        <input type="number" class="pct-custom-input" data-field="pct-custom-asesor" data-row="${rowCounter}" style="display:none;" placeholder="%" step="0.01" min="0">
                    </div>
                </div>`;
            container.appendChild(newRow);
            initializeCustomSelects();
            const newSelectors = newRow.querySelectorAll('.custom-select[data-api]');
            for (const selector of newSelectors) await loadSelectorData(selector);
            newRow.style.opacity = '0'; newRow.style.transform = 'translateY(-20px)';
            setTimeout(() => { newRow.style.transition = 'all 0.4s ease'; newRow.style.opacity = '1'; newRow.style.transform = 'translateY(0)'; }, 10);
            updatePercentageDefaults();
        }

        function deletePersonnelRow() {
            const container = document.getElementById('personnelRows');
            const rows = container.querySelectorAll('.personnel-row');
            if (rows.length > 1) { rows[rows.length - 1].remove(); rowCounter--; }
            updatePercentageDefaults();
        }

        function cancelForm() { document.getElementById('confirmModal').classList.add('active'); }

        function resetFormSilently() {
            document.getElementById('commissionForm').reset();
            document.getElementById('fechaRegistro').valueAsDate = new Date();
            document.querySelectorAll('.has-error').forEach(el => el.classList.remove('has-error'));
            document.querySelectorAll('.valid').forEach(el => el.classList.remove('valid'));
            document.querySelectorAll('.field-error.visible').forEach(el => el.classList.remove('visible'));
            document.querySelectorAll('.select-display').forEach(display => {
                const cs = display.closest('.custom-select');
                if (!cs) return;
                const placeholder = cs.querySelector('.select-search input').placeholder;
                display.textContent = placeholder.replace('Buscar', 'Seleccionar');
                display.classList.add('placeholder'); display.classList.remove('auto-selected');
                delete display.dataset.value;
                const arrow = document.createElement('i');
                arrow.className = 'fas fa-chevron-down select-arrow';
                display.appendChild(arrow);
            });
            populateSelect(document.querySelector('.custom-select[data-field="desarrollo"]'), allData.desarrollos);
            populateSelect(document.querySelector('.custom-select[data-field="ubicacion"]'), allData.ubicaciones);
        }

        function formatSalePrice(input) {
            let val = input.value.replace(/[^0-9]/g, '');
            input.dataset.raw = val;
            if (val) {
                val = parseInt(val).toLocaleString('es-MX');
                input.value = '$' + val;
            } else {
                input.value = '';
            }
        }


        let cachedPorcentajes = null;
        async function fetchPorcentajes() {
            if (cachedPorcentajes) return cachedPorcentajes;
            try {
                const response = await fetch("/api/percentages/");
                if (!response.ok) throw new Error("Respuesta no válida");
                cachedPorcentajes = await response.json();
                return cachedPorcentajes;
            } catch (error) {
                showAlert('Error de porcentajes', 'No se pudo obtener los porcentajes de comisión. El registro ha sido cancelado.', 'error');
                return null;
            }
        }

        async function updatePercentageDefaults() {
            const porcentajes = await fetchPorcentajes();
            if (!porcentajes || !porcentajes.data) return;
            
            const mp = document.getElementById('mpCheckbox').checked;
            const commissionType = mp ? 'multipoint' : (rowCounter === 1 ? 'traditional' : 'shared');
            const rates = porcentajes.data[commissionType];
            
            document.querySelectorAll('.personnel-row').forEach((row, index) => {
                const rowNum = index + 1;
                const managerKey = `manager${rowNum}`;
                const advisorKey = `advisor${rowNum}`;
                
                const pctGerente = row.querySelector(`.pct-select[data-field="pct-gerente"][data-row="${rowNum}"]`);
                if (pctGerente && rates[managerKey] !== undefined && !pctGerente.dataset.userEdited) {
                    pctGerente.value = rates[managerKey];
                }
                
                const pctAsesor = row.querySelector(`.pct-select[data-field="pct-asesor"][data-row="${rowNum}"]`);
                if (pctAsesor && rates[advisorKey] !== undefined && !pctAsesor.dataset.userEdited) {
                    pctAsesor.value = rates[advisorKey];
                }
            });
        }
        
        // Listen to manual user changes to prevent overriding them later
        document.addEventListener('change', (e) => {
            if (e.target.classList.contains('pct-select')) {
                e.target.dataset.userEdited = 'true';
                const row = e.target.dataset.row;
                const fieldSplit = e.target.dataset.field.split('-'); // pct-gerente -> ['pct', 'gerente']
                const customInput = document.querySelector(`.pct-custom-input[data-field="pct-custom-${fieldSplit[1]}"][data-row="${row}"]`);
                if (customInput) {
                    if (e.target.value === 'custom') {
                        customInput.style.display = 'block';
                        customInput.focus();
                    } else {
                        customInput.style.display = 'none';
                    }
                }
            }
        });

        async function buildPayLoad() {
            const compania      = getSelectValue("compania");
            const desarrollo    = getSelectValue("desarrollo");
            const ubicacion     = getSelectValue("ubicacion");
            const fechaRegistro = document.getElementById("fechaRegistro").value;
            const concepto      = getSelectValue("concepto");
            const fechaContrato = document.getElementById("fechaContrato").value;
            const salePrice     = parseFloat(document.getElementById("salePrice").dataset.raw) || 0;

            const mp            = document.getElementById('mpCheckbox').checked;
            
            const expedienteSelect = document.querySelector('.custom-select[data-field="expediente"] .select-display');
            const expediente_id = expedienteSelect && expedienteSelect.dataset.value ? expedienteSelect.dataset.value : null;
            const client_name = expedienteSelect && expedienteSelect.dataset.clientName ? expedienteSelect.dataset.clientName : null;

            const commissionTypeES = mp ? 'Multipunto' : (rowCounter === 1 ? 'Tradicional' : 'Compartida');
            const managers = [], advisors = [];
            document.querySelectorAll('.personnel-row').forEach((row, index) => {
                const rowNum = index + 1;
                const manager = getSelectValue('gerente', rowNum);
                const advisor = getSelectValue('asesor', rowNum);
                
                const pctGerenteSel = row.querySelector(`.pct-select[data-field="pct-gerente"][data-row="${rowNum}"]`);
                const pctAsesorSel = row.querySelector(`.pct-select[data-field="pct-asesor"][data-row="${rowNum}"]`);
                
                let mgrPct = pctGerenteSel ? parseFloat(pctGerenteSel.value) : 0;
                let advPct = pctAsesorSel ? parseFloat(pctAsesorSel.value) : 0;

                if (pctGerenteSel && pctGerenteSel.value === 'custom') {
                    const customInput = row.querySelector(`.pct-custom-input[data-field="pct-custom-gerente"][data-row="${rowNum}"]`);
                    mgrPct = customInput && customInput.value ? parseFloat(customInput.value) / 100 : 0;
                }
                if (pctAsesorSel && pctAsesorSel.value === 'custom') {
                    const customInput = row.querySelector(`.pct-custom-input[data-field="pct-custom-asesor"][data-row="${rowNum}"]`);
                    advPct = customInput && customInput.value ? parseFloat(customInput.value) / 100 : 0;
                }

                if (manager && manager.id) managers.push({ user: manager.id, name:manager.text, percentage: mgrPct, commission: salePrice * mgrPct });
                if (advisor && advisor.id) advisors.push({ user: advisor.id, name:advisor.text, percentage: advPct, commission: salePrice * advPct });
            });
            const isCancellation = concepto && concepto.text && concepto.text.toLowerCase() === 'cancelación';
            let penaltyTarget = null;
            if (isCancellation) {
                const targetRadio = document.querySelector('input[name="penaltyTarget"]:checked');
                penaltyTarget = targetRadio ? targetRadio.value : 'cliente';
            }

            return {
                company: compania, development: desarrollo, location: ubicacion,
                commission_type: commissionTypeES, register_date: fechaRegistro,
                operation_date: fechaContrato, sale_price: salePrice, concept: concepto,
                expediente_id: expediente_id, client_name: client_name,
                status: "Pendiente", participants: { managers, advisors },
                is_cancellation: isCancellation, penalty_target: penaltyTarget,
                created_at: new Date(), updated_at: new Date()
            };
        }

        // document.getElementById("commissionForm").addEventListener("submit", async (e) => {
        //     e.preventDefault();
        //     if (!validateForm()) return;
        //     const data = await buildPayLoad();
        //     if (!data) return;
        //     showPayloadModal(data);
        // });
        // Reemplaza el addEventListener del submit existente
document.getElementById('commissionForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  if (!validateForm()) return;
  const data = await buildPayLoad();
  if (!data) return;

//   if (isEditMode) {
//     // En modo edición mostramos el mismo modal de confirmación
//     // pero el botón "Confirmar y guardar" llama a PATCH en vez de POST
//     document.getElementById('confirmSaveBtn').onclick = async () => {
//       await updateCommission(editId, data);
//       closePayloadModal();
//     };
//   } 
    showPayloadModal(data);
  

});

async function updateCommission(comisionId, data) {
  try {
    const r = await fetch(`/api/comisiones/editar/${comisionId}`, {
      method:      'PATCH',
      headers:     { 'Content-Type': 'application/json' },
      credentials: 'include',
      body:        JSON.stringify(data),
    });
    const j = await r.json();
    if (!j.success) { showAlert('Error', j.message, 'error'); return; }

    showAlert('¡Comisión actualizada!',
      'Los cambios fueron guardados. El estatus y verificaciones fueron reiniciados.',
      'success');

    // Regresar al listado después de 1.5s
    setTimeout(() => window.location.href = '/', 1500);

  } catch(e) {
    showAlert('Error de conexión', 'No se pudo conectar con el servidor.', 'error');
  }
}
    </script>
</div><!-- /.main-area -->
