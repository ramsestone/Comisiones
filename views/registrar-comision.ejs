    <script>
        // --- Alert modal ---
        function showAlert(title, message, type = 'info') {
            const iconMap = { success: { cls: 'success', icon: 'fa-check-circle' }, error: { cls: 'error', icon: 'fa-times-circle' }, warning: { cls: 'warning', icon: 'fa-exclamation-triangle' }, info: { cls: 'info', icon: 'fa-info-circle' } };
            const t = iconMap[type] || iconMap.info;
            const iconEl = document.getElementById('alertModalIcon');
            iconEl.className = `novu-modal-icon ${t.cls}`;
            iconEl.innerHTML = `<i class="fas ${t.icon}"></i>`;
            document.getElementById('alertModalTitle').textContent = title;
            document.getElementById('alertModalMessage').textContent = message;
            document.getElementById('alertModal').classList.add('active');
        }
        function closeAlertModal() { document.getElementById('alertModal').classList.remove('active'); }

        function closeConfirmModal() { document.getElementById('confirmModal').classList.remove('active'); }
        function confirmCancel() { closeConfirmModal(); resetFormSilently(); }

        let pendingPayload = null;

        function showPayloadModal(data) {
            pendingPayload = data;
            const body = document.getElementById('payloadModalBody');
            const fmt = (v) => v || '<span style="color:#555">—</span>';
            const fmtMoney = (v) => v ? '$' + Number(v).toLocaleString('es-MX') : '—';
            const fmtPct = (v) => v != null ? (v * 100).toFixed(2) + '%' : '—';
            let html = '';
            html += `<div class="payload-section-label"><i class="fas fa-info-circle"></i> Información general</div>`;
            html += `<div class="payload-grid">
                <div class="payload-field"><div class="payload-field-label">Compañía</div><div class="payload-field-value">${fmt(data.company?.text)}</div></div>
                <div class="payload-field"><div class="payload-field-label">Desarrollo</div><div class="payload-field-value">${fmt(data.development?.text)}</div></div>
                <div class="payload-field"><div class="payload-field-label">Ubicación</div><div class="payload-field-value">${fmt(data.location?.text)}</div></div>
                <div class="payload-field"><div class="payload-field-label">Concepto</div><div class="payload-field-value">${fmt(data.concept?.text)}</div></div>
                <div class="payload-field"><div class="payload-field-label">Fecha registro</div><div class="payload-field-value">${fmt(data.register_date)}</div></div>
                <div class="payload-field"><div class="payload-field-label">Fecha contrato</div><div class="payload-field-value">${fmt(data.operation_date)}</div></div>
            </div>`;
            html += `<div class="payload-section-label"><i class="fas fa-dollar-sign"></i> Operación</div>`;
            html += `<div class="payload-grid">
                <div class="payload-field"><div class="payload-field-label">Precio de venta</div><div class="payload-field-value money">${fmtMoney(data.sale_price)}</div></div>
                <div class="payload-field"><div class="payload-field-label">Tipo de comisión</div><div class="payload-field-value accent">${fmt(data.commission_type)}</div></div>
                <div class="payload-field"><div class="payload-field-label">Estatus</div><div class="payload-field-value">${fmt(data.status)}</div></div>
            </div>`;
            if (data.participants?.managers?.length) {
                html += `<div class="payload-section-label"><i class="fas fa-user-tie"></i> Gerentes</div>`;
                data.participants.managers.forEach((m, i) => { html += `<div class="participant-card"><div class="participant-role"><i class="fas fa-hashtag"></i> Gerente ${i + 1}</div><div class="participant-row"><span class="participant-name">${m.name || m.user}</span><span class="participant-pct">${fmtPct(m.percentage)}</span><span class="participant-commission">${fmtMoney(m.commission)}</span></div></div>`; });
            }
            if (data.participants?.advisors?.length) {
                html += `<div class="payload-section-label"><i class="fas fa-user"></i> Asesores</div>`;
                data.participants.advisors.forEach((a, i) => { html += `<div class="participant-card"><div class="participant-role"><i class="fas fa-hashtag"></i> Asesor ${i + 1}</div><div class="participant-row"><span class="participant-name">${a.name || a.user}</span><span class="participant-pct">${fmtPct(a.percentage)}</span><span class="participant-commission">${fmtMoney(a.commission)}</span></div></div>`; });
            }
            body.innerHTML = html;
            document.getElementById('payloadModal').classList.add('active');
        }

        function closePayloadModal() { document.getElementById('payloadModal').classList.remove('active'); pendingPayload = null; }

        document.getElementById('confirmSaveBtn').addEventListener('click', async () => {
            if (!pendingPayload) return;
            if (isEditMode) {
                await updateCommission(editId, pendingPayload);
            } else{
                await sendCommission(pendingPayload);
            }
            closePayloadModal();
        });

        async function sendCommission(data) {
            try {
                const response = await fetch('/api/comisiones/', {
                    method:      'POST',
                    headers:     { 'Content-Type': 'application/json' },
                    credentials: 'include',   // ← envía la cookie → el servidor lee req.user.id
                    body:        JSON.stringify(data)
                });

                const result = await response.json();
                console.log(result);

                if (!response.ok) {
                    showAlert('Error al guardar', result.message || 'No se pudo registrar la comisión.', 'error');
                    return;
                }

                showAlert('¡Comisión registrada!', 'La comisión fue guardada exitosamente.', 'success');
                resetFormSilently();

            } catch (error) {
                showAlert('Error de conexión', 'No se pudo conectar con el servidor. Intenta de nuevo.', 'error');
            }
        }

        document.querySelectorAll('.novu-modal-overlay').forEach(overlay => {
            overlay.addEventListener('click', (e) => { if (e.target === overlay) overlay.classList.remove('active'); });
        });
    </script>

    <script>
        const apiCache = {};
        const allData = { desarrollos: [], ubicaciones: [], expedientes: [] };

        async function fetchFromAPI(endpoint) {
            if (endpoint == "/v10/conceptos") {
                const data = [{id:1,nombre:"Contrato"},{id:2,nombre:"Escritura"},{id:3,nombre:"Cancelación"}];
                allData.conceptos = data;
                return data;
            }
            if (apiCache[endpoint]) return apiCache[endpoint];
            try {
                const response = await fetch(`${endpoint}`);
                if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
                const result = await response.json();
                if (result.success && result.data) {
                    let data = [];
                    if (result.data.desarrollos) { data = result.data.desarrollos; allData.desarrollos = [...data]; }
                    else if (result.data.companias) { data = result.data.companias; }
                    else if (result.data.ubicaciones) { data = result.data.ubicaciones; allData.ubicaciones = [...data]; }
                    else if (result.data.conceptos) { data = result.data.conceptos; allData.conceptos = [...data]; }
                    else if (result.data.expedientes) { data = result.data.expedientes; allData.expedientes = [...data]; }
                    else if (result.data && endpoint == "/api/users/by-role/Gerente") { data = result.data.map(user => ({ id: user._id, nombre: user.name })); }
                    else if (result.data && endpoint == "/api/users/by-role/Asesor") { data = result.data.map(user => ({ id: user._id, nombre: user.name, manager_ids: user.manager_ids })); }
                    apiCache[endpoint] = data;
                    return data;
                } else { throw new Error('Formato de respuesta inválido'); }
            } catch (error) { console.error(`Error al obtener datos de ${endpoint}:`, error); throw error; }
        }

// Fuera de DOMContentLoaded — scope global
const params         = new URLSearchParams(window.location.search);
const editId         = params.get('edit');
const fromContratoId = params.get('fromContrato');
const isEditMode     = !!editId;
const isFromContrato = !!fromContratoId;

const CURRENT_USER = <%- JSON.stringify(user || {}) %>;

document.addEventListener('DOMContentLoaded', async function() {
    document.getElementById('fechaRegistro').valueAsDate = new Date();
    initializeCustomSelects();
    await loadAllSelectors(); // ← await aquí, esperar a que terminen TODAS las APIs

    if (isEditMode) {
        document.querySelector('h1').textContent = 'Editar Comisión';
        document.querySelector('.btn-primary').innerHTML = '<i class="fas fa-save"></i> Guardar cambios';
        await loadComisionForEdit(editId); // ← ahora allData ya está lleno
    } else if (isFromContrato) {
        document.querySelector('h1').textContent = 'Registrar Comisión de Escritura';
        await loadComisionForEdit(fromContratoId, true);
    } else {
        const contratoC = allData.conceptos?.find(c => c.nombre && c.nombre.toLowerCase() === 'contrato');
        if (contratoC) setSelectValue('concepto', String(contratoC.id));
        const cSelect = document.querySelector('.custom-select[data-field="concepto"]');

        if (CURRENT_USER && CURRENT_USER.roleName === 'Gerente') {
            const manager1 = document.querySelector('.custom-select[data-field="gerente"][data-row="1"]');
            if (manager1) {
                const option = manager1.querySelector(`.select-option[data-value="${CURRENT_USER.id}"]`);
                if (option) selectOptionSilent(manager1, option);
            }
        }
    }
    
    await updatePercentageDefaults();

    document.getElementById('fechaContrato').addEventListener('change', function() {
        if (this.value) { clearFieldError('fechaContrato'); this.classList.remove('has-error'); this.classList.add('valid'); }
    });
    document.getElementById('salePrice').addEventListener('input', function() {
        if (this.dataset.raw && parseInt(this.dataset.raw) > 0) { clearFieldError('salePrice'); this.classList.remove('has-error'); this.classList.add('valid'); }
    });

});

        /// EDIDDIDIT
async function loadComisionForEdit(comisionId, fromContratoMode = false) {
  try {
    const r = await fetch(`/api/comisiones/obtener/${comisionId}`, { credentials: 'include' });
    const j = await r.json();
    if (!j.success) { showAlert('Error', j.message, 'error'); return; }

    const c            = j.data.comision;
    const participantes = j.data.participantes; // por si también los necesitas

