        function clearSelection(field) {
            const selector = document.querySelector(`.custom-select[data-field="${field}"]`);
            if (selector) {
                const display = selector.querySelector('.select-display');
                const placeholder = selector.querySelector('.select-search input').placeholder;
                display.textContent = placeholder.replace('Buscar', 'Seleccionar');
                display.classList.add('placeholder'); display.classList.remove('auto-selected');
                delete display.dataset.value; delete display.dataset.compania; delete display.dataset.desarrollo;
                const badge = display.querySelector('.auto-select-badge');
                if (badge) badge.remove();
                const arrow = document.createElement('i');
                arrow.className = 'fas fa-chevron-down select-arrow';
                display.appendChild(arrow);
                selector.querySelectorAll('.select-option').forEach(opt => opt.classList.remove('selected'));
            }
        }

        function initializeCustomSelects() {
            document.querySelectorAll('.custom-select:not(.initialized)').forEach(select => {
                select.classList.add('initialized');
                const display = select.querySelector('.select-display');
                const dropdown = select.querySelector('.select-dropdown');
                const searchInput = select.querySelector('.select-search input');
                if (display && dropdown) {
                    display.addEventListener('click', (e) => {
                        e.stopPropagation();
                        if (display.classList.contains('loading')) return;
                        
                        const wasActive = display.classList.contains('active');
                        closeAllSelects();
                        
                        if (!wasActive) {
                            dropdown.classList.add('active');
                            display.classList.add('active');
                            select.classList.add('active');
                            
                            const formGroup = select.closest('.form-group');
                            if (formGroup) {
                                formGroup.classList.add('active-dropdown-parent');
                                formGroup.style.zIndex = '9999';
                                formGroup.style.position = 'relative';
                            }
                            
                            const personnelRow = select.closest('.personnel-row') || select.closest('.form-grid');
                            if (personnelRow) {
                                personnelRow.classList.add('active-dropdown-parent');
                                personnelRow.style.zIndex = '9999';
                                personnelRow.style.position = 'relative';
                            }
                            
                            if (searchInput) searchInput.focus();
                        }
                    });
                }
                if (searchInput) {
                    searchInput.addEventListener('input', function() {
                        const searchTerm = this.value.toLowerCase();
                        const options = select.querySelectorAll('.select-option');
                        let hasResults = false;
                        options.forEach(option => {
                            if (option.classList.contains('filtered-out')) return;
                            const text = option.textContent.toLowerCase();
                            if (text.includes(searchTerm)) { option.classList.remove('hidden'); hasResults = true; }
                            else option.classList.add('hidden');
                        });
                        let noResults = select.querySelector('.no-results');
                        if (!hasResults && searchTerm) {
                            if (!noResults) { noResults = document.createElement('div'); noResults.className = 'no-results'; noResults.innerHTML = '<i class="fas fa-search"></i> No se encontraron resultados'; dropdown.appendChild(noResults); }
                        } else if (noResults) noResults.remove();
                    });
                }
                if (dropdown) dropdown.addEventListener('click', (e) => e.stopPropagation());
            });
            document.removeEventListener('click', closeAllSelects);
            document.addEventListener('click', closeAllSelects);
        }

        function closeAllSelects() {
            document.querySelectorAll('.select-dropdown.active').forEach(dropdown => {
                dropdown.classList.remove('active');
                if (dropdown.previousElementSibling) dropdown.previousElementSibling.classList.remove('active');
                
                const select = dropdown.closest('.custom-select');
                if (select) select.classList.remove('active');
                
                document.querySelectorAll('.active-dropdown-parent').forEach(el => {
                    el.classList.remove('active-dropdown-parent');
                    el.style.zIndex = '';
                    if (!el.classList.contains('personnel-row')) el.style.position = '';
                });
                
                const searchInput = dropdown.querySelector('.select-search input');
                if (searchInput) { searchInput.value = ''; dropdown.querySelectorAll('.select-option').forEach(opt => opt.classList.remove('hidden')); }
                const noResults = dropdown.querySelector('.no-results');
                if (noResults) noResults.remove();
            });
        }

        function getSelectValue(fieldName, rowNumber = null) {
            const selector = rowNumber
                ? `.custom-select[data-field="${fieldName}"][data-row="${rowNumber}"]`
                : `.custom-select[data-field="${fieldName}"]`;
            const selectElement = document.querySelector(selector);
            if (!selectElement) return null;
            const display = selectElement.querySelector('.select-display');
            return { id: display.dataset.value || '', text: display.classList.contains('placeholder') ? '' : display.textContent.replace('Auto', '').trim() };
        }

        function showFieldError(key) {
            const el = document.querySelector(`.field-error[data-for="${key}"]`);
            if (el) el.classList.add('visible');
        }
        function clearFieldError(key) {
            const el = document.querySelector(`.field-error[data-for="${key}"]`);
            if (el) el.classList.remove('visible');
        }

        function validateForm() {
            let valid = true;
            let firstInvalid = null;

            ['compania', 'desarrollo', 'ubicacion', 'concepto', 'expediente'].forEach(field => {
                const sel = document.querySelector(`.custom-select[data-field="${field}"]`);
                const display = sel ? sel.querySelector('.select-display') : null;
                if (!display || !display.dataset.value) {
                    showFieldError(field);
                    if (sel) { sel.classList.add('has-error'); if (!firstInvalid) firstInvalid = sel; }
                    valid = false;
                }
            });

            const fechaContrato = document.getElementById('fechaContrato');
            if (!fechaContrato.value) {
                showFieldError('fechaContrato');
                fechaContrato.classList.add('has-error');
                if (!firstInvalid) firstInvalid = fechaContrato;
                valid = false;
            }

            const salePriceEl = document.getElementById('salePrice');
            if (!salePriceEl.dataset.raw || parseInt(salePriceEl.dataset.raw) <= 0) {
                showFieldError('salePrice');
                salePriceEl.classList.add('has-error');
                if (!firstInvalid) firstInvalid = salePriceEl;
                valid = false;
            }

            document.querySelectorAll('.personnel-row').forEach((row, index) => {
                const rowNum = index + 1;
                const isFirstRow = rowNum === 1;
                if (isFirstRow) {
                    ['gerente', 'asesor'].forEach(field => {
                        const sel = row.querySelector(`.custom-select[data-field="${field}"]`);
                        const display = sel ? sel.querySelector('.select-display') : null;
                        if (!display || !display.dataset.value) {
                            showFieldError(`${field}-${rowNum}`);
                            if (sel) { sel.classList.add('has-error'); if (!firstInvalid) firstInvalid = sel; }
                            valid = false;
                        }
                    });
                } else {
                    ['gerente', 'asesor'].forEach(field => {
                        const sel = row.querySelector(`.custom-select[data-field="${field}"]`);
                        if (sel) { sel.classList.remove('has-error'); clearFieldError(`${field}-${rowNum}`); }
                    });
                }
            });

            if (!valid && firstInvalid) {
                firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }

            return valid;
        }

