<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="icon" type="image/svg+xml" href="/img/bill-icon.svg">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/styles/normalizer.css">
    <link rel="stylesheet" href="/styles/login.css">
    <link rel="stylesheet" href="/styles/loader.css">
</head>
<body>

    <div class="loader-container">
        <div class="loader"></div>
        <div class="loader-text">Cargando...</div>
    </div>

    <div class="login-container">
        <div class="left-panel">
            <div class="logo-container">
                <img src="./img/novu-logo.png" alt="Logo" class="logo-icon">
            </div>
            <div class="form-content">
                <div class="form-header">
                    <h1 class="form-title">Inicia sesión en tu cuenta</h1>
                </div>
                <form class="login-form" onsubmit="handleLogin(event)">
                    <div class="form-group">
                        <label class="form-label" for="username">Usuario</label>
                        <input type="text" id="username" class="form-input" placeholder="Tu nombre de usuario" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="password">Contraseña</label>
                        <input type="password" id="password" class="form-input" placeholder="••••••••" required>
                    </div>
                    <button type="submit" class="submit-button" id="login-button">Iniciar Sesión</button>
                    <div id="login-message" class="message"></div>
                </form>
                <p class="form-note">Si aún no estás registrado, comunícate con el administrador.</p>
            </div>
            <div class="form-footer">
                <a href="#">Ayuda</a>
                <a href="#">Términos y Condiciones</a>
                <a href="#">Legal</a>
                <a href="#">Contacto</a>
            </div>
        </div>

        <div class="right-panel">
            <div class="image-container">
                <img src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=1600&h=900&fit=crop" alt="Ciudad" class="background-image">
                <div class="image-overlay"></div>
            </div>
            
        </div>
    </div>

    <script src="/scripts/loginAuthentication.js"></script>
</body>
</html>