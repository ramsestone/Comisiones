<!DOCTYPE html>
<html lang="es">
<head>
    <link rel="icon" type="image/svg+xml" href="/img/bill-icon.svg">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registro de Usuario - Sistema NOVA</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/styles/layout.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #0f1e1e; color: #ffffff; min-height: 100vh;
            overflow-x: hidden;
        }
        body::before {
            content: ''; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background:
                radial-gradient(circle at 20% 50%, rgba(96,230,26,0.08) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(96,230,26,0.06) 0%, transparent 50%),
                linear-gradient(135deg, #0f1e1e 0%, #162828 50%, #0f1e1e 100%);
            z-index: -1;
        }
        .loader-container {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: #0f1e1e; display: flex; flex-direction: column;
            justify-content: center; align-items: center; z-index: 9999;
            animation: fadeOut 0.6s ease-out 2s forwards;
        }
        .loader { width: 70px; height: 70px; border: 3px solid rgba(96,230,26,0.2); border-top: 3px solid #60e61a; border-radius: 50%; animation: spin 1s cubic-bezier(0.68,-0.55,0.265,1.55) infinite; margin-bottom: 20px; }
        .loader-text { color: #60e61a; font-size: 0.9rem; font-weight: 500; letter-spacing: 2px; text-transform: uppercase; }
        @keyframes spin    { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        @keyframes fadeOut { to { opacity: 0; visibility: hidden; } }
        @keyframes fadeIn  { to { opacity: 1; } }

        .registration-container {
            width: 100%; max-width: 1000px; margin: 2rem auto; background: #0f1e1e;
            backdrop-filter: blur(10px); border-radius: 24px;
            border: 1px solid rgba(255,255,255,0.05);
            box-shadow: 0 20px 60px rgba(0,0,0,0.5); overflow: hidden;
            /* opacity: 0; animation: fadeIn 0.8s ease-out 2.3s forwards; */
        }
        .registration-header { padding: 40px; border-bottom: 1px solid rgba(255,255,255,0.05); text-align: center; }
        .header-badge { display: inline-block; background: rgba(96,230,26,0.15); border: 1px solid rgba(96,230,26,0.3); color: #60e61a; padding: 6px 16px; border-radius: 30px; font-size: 0.75rem; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 15px; }
        .registration-title { font-size: 2.5rem; font-weight: 800; background: linear-gradient(135deg, #ffffff 0%, #a0a0a0 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; letter-spacing: -1px; margin-bottom: 10px; }
        .registration-subtitle { color: #888; font-size: 0.95rem; }
        .registration-body { padding: 40px; }
        .form-section { margin-bottom: 35px; }
        .section-title { font-size: 1.2rem; font-weight: 700; color: #60e61a; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
        .section-title i { font-size: 1rem; }
        .form-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
        .form-group { display: flex; flex-direction: column; gap: 8px; }
        .form-group.full-width { grid-column: 1 / -1; }
        .form-label { font-size: 0.85rem; font-weight: 600; color: #8fada0; text-transform: uppercase; letter-spacing: 0.5px; display: flex; align-items: center; gap: 5px; }
        .form-label .required { color: #e74c3c; }
        .form-label .optional { color: #666; text-transform: lowercase; font-size: 0.75rem; font-weight: 400; }
        .form-input { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 14px 16px; color: #ffffff; font-size: 0.95rem; transition: all 0.3s ease; font-family: inherit; }
        .form-select { background: rgba(56,197,245,0.12); border: 1px solid rgba(56,197,245,0.3); border-radius: 12px; padding: 14px 16px; color: #38c5f5; font-size: 0.95rem; transition: all 0.3s ease; font-family: inherit; cursor: pointer; }
        .form-input:focus { outline: none; border-color: rgba(96,230,26,0.5); background: rgba(255,255,255,0.08); box-shadow: 0 0 0 3px rgba(96,230,26,0.1); }
        .form-select:focus, .form-select:hover { outline: none; border-color: #38c5f5; background: #0f1e1e; color: #fff; box-shadow: 0 0 0 3px rgba(56,197,245,0.1); }
        .form-select option { background: #0f1e1e; color: #ffffff; }
        .input-with-icon { position: relative; }
        .input-with-icon i { position: absolute; right: 16px; top: 50%; transform: translateY(-50%); color: #666; pointer-events: none; }
        .input-with-icon input { padding-right: 45px; }
        .password-toggle { position: absolute; right: 16px; top: 50%; transform: translateY(-50%); color: #888; cursor: pointer; transition: color 0.3s; pointer-events: all; }
        .password-toggle:hover { color: #60e61a; }
        .avatar-upload { display: flex; align-items: center; gap: 20px; }
        .avatar-preview { width: 100px; height: 100px; border-radius: 50%; border: 3px solid rgba(96,230,26,0.4); background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center; font-size: 2.5rem; color: #60e61a; overflow: hidden; position: relative; }
        .avatar-preview img { width: 100%; height: 100%; object-fit: cover; display: none; }
        .avatar-preview i { position: absolute; }
        .avatar-preview.has-image i { display: none; }
        .avatar-preview.has-image img { display: block; }
        .file-input-wrapper { position: relative; flex: 1; }
        .file-input-btn { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 14px 20px; color: #aaa; font-size: 0.9rem; cursor: pointer; transition: all 0.3s ease; display: flex; align-items: center; gap: 10px; width: 100%; }
        .file-input-btn:hover { background: rgba(255,255,255,0.08); border-color: rgba(96,230,26,0.3); }
        .file-input-btn i { color: #60e61a; }
        input[type="file"] { display: none; }
        .checkbox-group { display: flex; align-items: center; gap: 10px; margin-top: 10px; }
        .custom-checkbox { position: relative; width: 20px; height: 20px; cursor: pointer; }
        .custom-checkbox input { position: absolute; opacity: 0; cursor: pointer; }
        .checkmark { position: absolute; top: 0; left: 0; height: 20px; width: 20px; background: rgba(255,255,255,0.05); border: 2px solid rgba(255,255,255,0.1); border-radius: 6px; transition: all 0.3s; }
        .custom-checkbox input:checked ~ .checkmark { background: linear-gradient(135deg, #60e61a, #3a9010); border-color: #60e61a; }
        .checkmark:after { content: ""; position: absolute; display: none; left: 5px; top: 2px; width: 5px; height: 10px; border: solid white; border-width: 0 2px 2px 0; transform: rotate(45deg); }
        .custom-checkbox input:checked ~ .checkmark:after { display: block; }
        .checkbox-label { color: #8fada0; font-size: 0.9rem; user-select: none; }
        .checkbox-label a { color: #60e61a; text-decoration: none; transition: color 0.3s; }
        .checkbox-label a:hover { color: #7af028; }
        .form-actions { display: flex; gap: 15px; margin-top: 30px; }
        .btn { flex: 1; padding: 16px 24px; border-radius: 12px; border: none; font-size: 1rem; font-weight: 600; cursor: pointer; transition: all 0.3s ease; display: flex; align-items: center; justify-content: center; gap: 10px; }
        .btn-secondary { background: rgba(255,255,255,0.05); color: #8fada0; }
        .btn-secondary:hover { background: rgba(255,255,255,0.1); color: #fff; }
        .btn-primary { background: linear-gradient(135deg, #60e61a, #3a9010); color: #ffffff; box-shadow: 0 4px 15px rgba(96,230,26,0.3); }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 25px rgba(96,230,26,0.4); }
        .btn-primary:active { transform: translateY(0); }
        .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
        .login-link { text-align: center; margin-top: 25px; padding-top: 25px; border-top: 1px solid rgba(255,255,255,0.05); color: #888; font-size: 0.9rem; }
        .login-link a { color: #60e61a; text-decoration: none; font-weight: 600; transition: color 0.3s; }
        .login-link a:hover { color: #7af028; }

        /* Mensajes de estado */
        .status-msg { display: none; padding: 15px 20px; border-radius: 12px; margin-bottom: 20px; align-items: center; gap: 12px; animation: slideDown 0.3s ease; }
        .status-msg.show { display: flex; }
        .status-msg.success { background: rgba(96,230,26,0.15); border: 1px solid rgba(96,230,26,0.3); color: #7af028; }
        .status-msg.error   { background: rgba(231,76,60,0.1);  border: 1px solid rgba(231,76,60,0.3); color: #e74c3c; }

        .error-message { color: #e74c3c; font-size: 0.8rem; margin-top: 5px; display: none; }
        .error-message.show { display: block; }

        .connection-status { position: fixed; top: 10px; right: 10px; padding: 5px 10px; border-radius: 5px; font-size: 12px; z-index: 1000; }
        .connection-status.connected    { background: rgba(96,230,26,0.2); color: #7af028; border: 1px solid rgba(96,230,26,0.3); }
        .connection-status.disconnected { background: rgba(231,76,60,0.2);  color: #e74c3c; border: 1px solid rgba(231,76,60,0.3); }

        @keyframes slideDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }

        @media (max-width: 768px) {
            .registration-title { font-size: 2rem; }
            .registration-header, .registration-body { padding: 30px 25px; }
            .form-grid { grid-template-columns: 1fr; }
            .form-actions { flex-direction: column-reverse; }
            .avatar-upload { flex-direction: column; text-align: center; }
        }
        @media (max-width: 480px) {
            .registration-title { font-size: 1.5rem; }
            .registration-header, .registration-body { padding: 25px 20px; }
        }

        /* ── Starfield + Beam + Dots ── */
        .stars { position: fixed; inset: 0; pointer-events: none; z-index: 0; }
        .star  { position: absolute; border-radius: 50%; animation: twinkle var(--dur) ease-in-out infinite alternate; }
        @keyframes twinkle { from { opacity: 0.2; transform: scale(1); } to { opacity: 1; transform: scale(1.4); } }
        .beam  { position: fixed; top: 0; right: 15%; width: 260px; height: 100vh; background: linear-gradient(180deg, rgba(96,230,26,0.07) 0%, transparent 70%); transform: skewX(-8deg); pointer-events: none; z-index: 0; }
    </style>
</head>
<body>

<div class="stars" id="stars"></div>
<div class="beam"></div>

<%- include('partials/sidebar') %>
<div class="main-area">
<%- include('partials/header') %>

    <!-- <div class="loader-container">
        <div class="loader"></div>
        <div class="loader-text">Cargando...</div>
    </div> -->

    <div class="registration-container">
        <div class="registration-header">
            <!-- <div class="header-badge">Sistema NOVA</div> -->
            <h1 class="registration-title">Registro de Usuario</h1>
            <p class="registration-subtitle">Completa el formulario para crear una nueva cuenta en el sistema</p>
        </div>

        <div class="registration-body">

            <!-- Mensaje de estado (éxito o error) -->
            

            <form id="registrationForm">
                <!-- Información Personal -->
                <div class="form-section">
                    <h3 class="section-title"><i class="fas fa-user"></i> Información Personal</h3>
                    <div class="form-grid">

                        <div class="form-group full-width">
                            <label class="form-label">Nombre Completo <span class="required">*</span></label>
                            <input type="text" class="form-input" id="nombres" placeholder="Juan Carlos Mendez" required>
                            <span class="error-message" id="nombresError">Este campo es requerido</span>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Correo Electrónico <span class="required">*</span></label>
                            <div class="input-with-icon">
                                <input type="email" class="form-input" id="correo" placeholder="juan@ejemplo.com" required>
                                <i class="fas fa-envelope"></i>
                            </div>
                            <span class="error-message" id="correoError">Ingresa un correo válido</span>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Teléfono <span class="required">*</span></label>
                            <div class="input-with-icon">
                                <input type="tel" class="form-input" id="telefono" placeholder="5512345678" required>
                                <i class="fas fa-phone"></i>
                            </div>
                            <span class="error-message" id="telefonoError">Ingresa un teléfono de 10 dígitos</span>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Tipo de Sangre</label>
                            <select class="form-select" id="tipo_sangre">
                                <option value="">Seleccionar tipo</option>
                                <option value="O+">O+</option><option value="O-">O-</option>
                                <option value="A+">A+</option><option value="A-">A-</option>
                                <option value="B+">B+</option><option value="B-">B-</option>
                                <option value="AB+">AB+</option><option value="AB-">AB-</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Fecha de Nacimiento</label>
                            <input type="date" class="form-input" id="fecha_nacimiento">
                        </div>

                        <div class="form-group">
                            <label class="form-label">Contacto de Emergencia</label>
                            <input type="text" class="form-input" id="nombre_contacto_emergencia" placeholder="Nombre completo">
                        </div>

                        <div class="form-group">
                            <label class="form-label">Teléfono de Emergencia</label>
                            <input type="text" class="form-input" id="telefono_contacto_emergencia" placeholder="5598765432">
                        </div>

                        <div class="form-group full-width">
                            <label class="form-label">Foto de Perfil <span class="optional">(opcional)</span></label>
                            <div class="avatar-upload">
                                <div class="avatar-preview" id="avatarPreview">
                                    <i class="fas fa-user"></i>
                                    <img src="" alt="Vista previa" id="avatarImage">
                                </div>
                                <div class="file-input-wrapper">
                                    <label for="foto_perfil" class="file-input-btn">
                                        <i class="fas fa-upload"></i>
                                        <span id="fileLabel">Seleccionar imagen (JPG, PNG - máx 2MB)</span>
                                    </label>
                                    <input type="file" id="foto_perfil" accept="image/jpeg,image/png,image/jpg">
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Información de Cuenta -->
                <div class="form-section">
                    <h3 class="section-title"><i class="fas fa-lock"></i> Información de Cuenta</h3>
                    <div class="form-grid">

                        <div class="form-group">
                            <label class="form-label">Rol <span class="required">*</span></label>
                            <select class="form-select" id="rol_id" required onchange="handleRoleChange(this.value)">
                                <option value="">Cargando roles...</option>
                            </select>
                            <span class="error-message" id="rol_idError">Selecciona un rol</span>
                        </div>

                        <div class="form-group" id="managerGroup" style="display: none;">
                            <label class="form-label">Gerente(s) Asignado(s) <span class="required">*</span></label>
                            <div id="managersContainer" style="display: flex; flex-direction: column; gap: 10px; max-height: 200px; overflow-y: auto; background: rgba(56,197,245,0.05); border: 1px solid rgba(56,197,245,0.2); border-radius: 12px; padding: 15px;">
                                <span style="color: #8fada0; font-size: 0.9rem;">Cargando gerentes...</span>
                            </div>
                            <span class="error-message" id="manager_idError">Selecciona al menos un gerente</span>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Nombre de Usuario <span class="required">*</span></label>
                            <div class="input-with-icon">
                                <input type="text" class="form-input" id="usuario" placeholder="juanperez" required>
                                <i class="fas fa-user-circle"></i>
                            </div>
                            <span class="error-message" id="usuarioError">El usuario debe tener al menos 4 caracteres</span>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Contraseña <span class="required">*</span></label>
                            <div class="input-with-icon">
                                <input type="password" class="form-input" id="contrasena" placeholder="••••••••" required>
                                <i class="fas fa-eye password-toggle" id="togglePassword"></i>
                            </div>
                            <span class="error-message" id="contrasenaError">La contraseña debe tener al menos 6 caracteres</span>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Confirmar Contraseña <span class="required">*</span></label>
                            <div class="input-with-icon">
                                <input type="password" class="form-input" id="confirmar_contrasena" placeholder="••••••••" required>
                                <i class="fas fa-eye password-toggle" id="toggleConfirmPassword"></i>
                            </div>
                            <span class="error-message" id="confirmar_contrasenaError">Las contraseñas no coinciden</span>
                        </div>

                    </div>

                    <div class="checkbox-group">
                        <label class="custom-checkbox">
                            <input type="checkbox" id="terms" required>
                            <span class="checkmark"></span>
                        </label>
                        <label for="terms" class="checkbox-label">
                            Acepto los <a href="#" onclick="return false">términos y condiciones</a>
                            y la <a href="#" onclick="return false">política de privacidad</a>
                        </label>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" onclick="window.history.back()">
                        <i class="fas fa-times"></i> Cancelar
                    </button>
                    <button type="submit" class="btn btn-primary" id="submitButton">
                        <i class="fas fa-user-plus"></i>
                        <span id="submitText">Crear Cuenta</span>
                    </button>
                </div>

                <div class="login-link">
                    ¿Ya tienes una cuenta? <a href="/">Inicia sesión aquí</a>
                </div>
            </form>

            
        </div>

        <div class="status-msg" id="statusMsg">
                <i id="statusIcon" class="fas fa-check-circle"></i>
                <span id="statusText"></span>
            </div>
    </div>

    <script>
        const form         = document.getElementById('registrationForm');
        const submitButton = document.getElementById('submitButton');
        const statusMsg    = document.getElementById('statusMsg');
        const statusIcon   = document.getElementById('statusIcon');
        const statusText   = document.getElementById('statusText');
        const rolSelect    = document.getElementById('rol_id');
        let fotoBase64     = null;

        // ── Init ─────────────────────────────────────────────────────────────
        document.addEventListener('DOMContentLoaded', () => {
            loadRoles();
            initImageUpload();
            // setTimeout(updateConnectionStatus, 1000);
            // setInterval(updateConnectionStatus, 30000);
        });

        let rolesCache = [];

        // ── Cargar roles desde la API ─────────────────────────────────────────
        async function loadRoles() {
            try {
                const res    = await fetch('/api/roles', { credentials: 'include' });
                const result = await res.json();

                if (result.success && result.data?.roles) {
                    rolesCache = result.data.roles;
                    rolSelect.innerHTML = '<option value="">Seleccionar rol</option>';
                    result.data.roles.forEach(rol => {
                        const opt = document.createElement('option');
                        opt.value       = rol._id;
                        opt.textContent = rol.name;
                        rolSelect.appendChild(opt);
                    });
                } else {
                    throw new Error(result.message || 'Error al cargar roles');
                }
            } catch (err) {
                console.error('Error cargando roles:', err);
                rolSelect.innerHTML = '<option value="">Error al cargar roles</option>';
            }
        }

        async function handleRoleChange(roleId) {
            const role = rolesCache.find(r => r._id === roleId);
            const managerGroup = document.getElementById('managerGroup');
            const managersContainer = document.getElementById('managersContainer');
            if (role && role.name === 'Asesor') {
                managerGroup.style.display = 'flex';
                if (managersContainer.innerHTML.includes('Cargando gerentes...')) {
                    try {
                        const res = await fetch('/api/users/by-role/Gerente');
                        const result = await res.json();
                        if (result.success && result.data) {
                            managersContainer.innerHTML = '';
                            result.data.forEach(m => {
                                const lbl = document.createElement('label');
                                lbl.className = 'custom-checkbox';
                                lbl.style.display = 'flex';
                                lbl.style.alignItems = 'center';
                                lbl.style.width = '100%';
                                
                                const inp = document.createElement('input');
                                inp.type = 'checkbox';
                                inp.name = 'manager_ids';
                                inp.value = m._id;
                                
                                const span = document.createElement('span');
                                span.className = 'checkmark';
                                span.style.position = 'relative';
                                
                                const text = document.createElement('span');
                                text.className = 'checkbox-label';
                                text.style.marginLeft = '25px';
                                text.textContent = m.name;
                                
                                lbl.appendChild(inp);
                                lbl.appendChild(span);
                                lbl.appendChild(text);
                                managersContainer.appendChild(lbl);
                            });
                        }
                    } catch (err) {
                        console.error('Error loading managers', err);
                        managersContainer.innerHTML = '<span style="color: #e74c3c;">Error al cargar gerentes</span>';
                    }
                }
            } else {
                managerGroup.style.display = 'none';
                document.querySelectorAll('input[name="manager_ids"]').forEach(cb => cb.checked = false);
            }
        }

        // ── Imagen de perfil ──────────────────────────────────────────────────
        function initImageUpload() {
            document.getElementById('foto_perfil').addEventListener('change', function (e) {
                const file = e.target.files[0];
                if (!file) {
                    resetAvatar(); return;
                }
                if (file.size > 2 * 1024 * 1024) {
                    showStatus('El archivo es demasiado grande. Máximo 2MB.', 'error'); this.value = ''; return;
                }
                if (!['image/jpeg', 'image/png', 'image/jpg'].includes(file.type)) {
                    showStatus('Solo se permiten archivos JPG y PNG.', 'error'); this.value = ''; return;
                }
                document.getElementById('fileLabel').textContent = file.name;
                const reader = new FileReader();
                reader.onload = e => {
                    document.getElementById('avatarImage').src = e.target.result;
                    document.getElementById('avatarPreview').classList.add('has-image');
                    fotoBase64 = file; // Usar el archivo File para multer
                };
                reader.readAsDataURL(file);
            });
        }

        function resetAvatar() {
            document.getElementById('fileLabel').textContent = 'Seleccionar imagen (JPG, PNG - máx 2MB)';
            document.getElementById('avatarImage').src = '';
            document.getElementById('avatarPreview').classList.remove('has-image');
            fotoBase64 = null;
        }

        // ── Submit ────────────────────────────────────────────────────────────
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            if (!validateForm()) return;

            showLoading(true);

            try {
                const formData = new FormData();
                formData.append('name', document.getElementById('nombres').value.trim());
                formData.append('email', document.getElementById('correo').value.trim());
                formData.append('phone', document.getElementById('telefono').value.trim());
                formData.append('blood_type', document.getElementById('tipo_sangre').value || '');
                formData.append('birth_date', document.getElementById('fecha_nacimiento').value || '');
                formData.append('emergency_contact_name', document.getElementById('nombre_contacto_emergencia').value.trim());
                formData.append('emergency_contact_phone', document.getElementById('telefono_contacto_emergencia').value.trim());
                formData.append('role', document.getElementById('rol_id').value);
                formData.append('username', document.getElementById('usuario').value.trim());
                formData.append('password', document.getElementById('contrasena').value);
                
                const managerCheckboxes = document.querySelectorAll('input[name="manager_ids"]:checked');
                managerCheckboxes.forEach(cb => formData.append('manager_ids', cb.value));
                
                if (fotoBase64 instanceof File) {
                    formData.append('picture', fotoBase64);
                }

                const response = await fetch('/api/users/', {
                    method:      'POST',
                    credentials: 'include',
                    body:        formData
                });

                const result = await response.json();  // ← result, no response

                if (result.success) {                  // ← result.success (bug fix)
                    showStatus(result.message || '¡Usuario creado correctamente!', 'success');
                    form.reset();
                    resetAvatar();
                    // setTimeout(() => { window.location.href = '/selector'; }, 2000);
                } else {
                    showStatus(result.message || 'Error al crear el usuario', 'error');
                }

            } catch (err) {
                console.error('Error en registro:', err);
                showStatus('Error de conexión con el servidor', 'error');
            } finally {
                showLoading(false);
            }
        });

        // ── Validación ────────────────────────────────────────────────────────
        function validateForm() {
            let ok = true;
            document.querySelectorAll('.error-message').forEach(el => el.classList.remove('show'));

            // Campos requeridos
            ['nombres', 'correo', 'telefono', 'rol_id', 'usuario', 'contrasena'].forEach(id => {
                const el = document.getElementById(id);
                if (!el.value.trim()) {
                    document.getElementById(`${id}Error`)?.classList.add('show');
                    ok = false;
                }
            });

            // Email
            if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(document.getElementById('correo').value)) {
                document.getElementById('correoError').classList.add('show'); ok = false;
            }

            // Usuario mínimo 4 chars
            if (document.getElementById('usuario').value.length < 4) {
                document.getElementById('usuarioError').classList.add('show'); ok = false;
            }
            
            if (document.getElementById('managerGroup').style.display === 'flex') {
                const checkedManagers = document.querySelectorAll('input[name="manager_ids"]:checked');
                if (checkedManagers.length === 0) {
                    document.getElementById('manager_idError').classList.add('show'); ok = false;
                }
            }

            // Contraseña mínimo 6 chars
            const pwd = document.getElementById('contrasena').value;
            if (pwd.length < 6) {
                document.getElementById('contrasenaError').classList.add('show'); ok = false;
            }

            // Confirmar contraseña
            if (pwd !== document.getElementById('confirmar_contrasena').value) {
                document.getElementById('confirmar_contrasenaError').classList.add('show'); ok = false;
            }

            // Términos
            if (!document.getElementById('terms').checked) {
                showStatus('Debes aceptar los términos y condiciones', 'error'); ok = false;
            }

            return ok;
        }

        // ── Helpers ───────────────────────────────────────────────────────────
        function showStatus(message, type) {
            statusMsg.className = `status-msg ${type} show`;
            statusIcon.className = type === 'success' ? 'fas fa-check-circle' : 'fas fa-circle-exclamation';
            statusText.textContent = message;
            if (type === 'error') setTimeout(() => statusMsg.classList.remove('show'), 5000);
        }

        function showLoading(isLoading) {
            submitButton.disabled = isLoading;
            submitButton.innerHTML = isLoading
                ? '<i class="fas fa-spinner fa-spin"></i> Registrando...'
                : '<i class="fas fa-user-plus"></i><span id="submitText">Crear Cuenta</span>';
        }

        async function updateConnectionStatus() {
            let ok = false;
            try { ok = (await fetch('/api/roles', { credentials: 'include' })).ok; } catch {}
            let el = document.querySelector('.connection-status');
            if (!el) { el = document.createElement('div'); document.body.appendChild(el); }
            el.className = `connection-status ${ok ? 'connected' : 'disconnected'}`;
            el.innerHTML = ok ? '<i class="fas fa-wifi"></i> Conectado' : '<i class="fas fa-wifi-slash"></i> Sin conexión';
        }

        // Toggle contraseña visible
        document.getElementById('togglePassword').addEventListener('click', function () {
            const input = document.getElementById('contrasena');
            input.type = input.type === 'password' ? 'text' : 'password';
            this.classList.toggle('fa-eye'); this.classList.toggle('fa-eye-slash');
        });
        document.getElementById('toggleConfirmPassword').addEventListener('click', function () {
            const input = document.getElementById('confirmar_contrasena');
            input.type = input.type === 'password' ? 'text' : 'password';
            this.classList.toggle('fa-eye'); this.classList.toggle('fa-eye-slash');
        });

        // Validación en tiempo real
        document.querySelectorAll('.form-input, .form-select').forEach(input => {
            input.addEventListener('blur', function () {
                const errEl = document.getElementById(`${this.id}Error`);
                if (errEl) errEl.classList.toggle('show', this.hasAttribute('required') && !this.value.trim());
            });
        });

        (function() {
            const starsEl = document.getElementById('stars');
            const colors = ['#ffffff','#7af028','#c8e88a','#60e61a'];
            for (let i = 0; i < 120; i++) {
                const s = document.createElement('div');
                s.className = 'star';
                const size = Math.random() * 3 + 1;
                s.style.cssText = `width:${size}px;height:${size}px;top:${Math.random()*100}%;left:${Math.random()*100}%;background:${colors[Math.floor(Math.random()*colors.length)]};--dur:${1.5+Math.random()*3}s;animation-delay:${Math.random()*3}s;opacity:${Math.random()*0.6+0.2};`;
                starsEl.appendChild(s);
            }
        })();
    </script>
</div><!-- /.main-area -->
</body>
</html>